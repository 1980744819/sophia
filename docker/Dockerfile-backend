# 构建阶段：使用 Maven 构建后端项目
FROM 192.168.1.7:30002/base/maven:3.8-openjdk-18-slim as build

# 设置工作目录
WORKDIR /app

# 设置环境变量
ENV http_proxy=http://192.168.1.7:7890 \
    https_proxy=http://192.168.1.7:7890 \
    no_proxy=localhost,127.0.0.1,192.168.0.0/16,10.0.0.0/8

# 设置国内镜像代理
RUN if [ -f /etc/apt/sources.list ]; then sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list && apt-get update; fi

# 设置 Maven 镜像源
RUN mkdir -p /root/.m2 && echo '<settings><mirrors><mirror><id>aliyun</id><name>Aliyun Maven</name><url>https://maven.aliyun.com/repository/public</url><mirrorOf>central</mirrorOf></mirror></mirrors></settings>' > /root/.m2/settings.xml

# 复制后端源代码
COPY source/xzs/ .

# 构建项目
RUN mvn clean package -DskipTests

# 运行阶段：使用 OpenJDK 18 运行后端项目
FROM 192.168.1.7:30002/base/openjdk:19-ea-jdk-alpine3.16

# 设置工作目录
WORKDIR /app

# 设置环境变量
ENV http_proxy=http://192.168.1.7:7890 \
    https_proxy=http://192.168.1.7:7890 \
    no_proxy=localhost,127.0.0.1,192.168.0.0/16,10.0.0.0/8

# 设置国内镜像代理
RUN if [ -f /etc/apk/repositories ]; then sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories; fi

# 复制构建好的 JAR 文件
COPY --from=build /app/target/xzs-*.jar ./xzs.jar

# 暴露 8000 端口
EXPOSE 8000

# 设置时区
ENV TZ=Asia/Shanghai
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# 启动应用
CMD ["java", "-Duser.timezone=Asia/Shanghai", "-jar", "xzs.jar", "--spring.profiles.active=prod"]